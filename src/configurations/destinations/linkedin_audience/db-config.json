{
  "name": "LINKEDIN_AUDIENCE",
  "displayName": "Linkedin Audience",
  "config": {
    "cdkV2Enabled": true,
    "transformAtV1": "router",
    "saveDestinationResponse": true,
    "syncBehaviours": ["mirror"],
    "supportedAccountDefinitions": {
      "rudderAccountId": ["DESTINATION_LINKEDIN_AUDIENCE_OAUTH"]
    },
    "auth": {
      "type": "OAuth",
      "role": "linkedin_audience",
      "rudderScopes": ["delivery"]
    },
    "isAudienceSupported": true,
    "supportedSourceTypes": ["warehouse"],
    "supportedMessageTypes": {
      "cloud": ["record"]
    },
    "supportedConnectionModes": {
      "warehouse": ["cloud"]
    },
    "destConfig": {
      "defaultConfig": ["rudderAccountId"],
      "warehouse": [
        "connectionMode"
      ]
    },
    "secretKeys": []
  },
  "options": {
    "isBeta": true,
    "hidden": false
  }
}
