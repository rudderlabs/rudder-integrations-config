{
  "secretSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "required": ["accessToken"],
    "type": "object",
    "properties": {
      "accessToken": {
        "type": "string",
        "pattern": "(^\\{\\{.*\\|\\|(.*)\\}\\}$)|^(.{1,500})$"
      },
      "appSecret": {
        "type": "string",
        "pattern": "(^\\{\\{.*\\|\\|(.*)\\}\\}$)|^(.{0,200})$"
      }
    }
  }
}
